# Copy this file to .env on the cloud server.
DATA_DIR=/srv/yolo-factory/data
MODEL_DIR=/srv/yolo-factory/models
WEB_PORT=8080
IMAGE_TAG=latest

# Optional comma-separated browser origins for direct cross-origin API access.
# Leave empty when the web UI uses the same host and port as the API proxy.
CORS_ALLOWED_ORIGINS=

# API container hard limits for an 8 vCPU / 16 GiB CPU server.
API_MEMORY_LIMIT=10g
API_CPU_LIMIT=6
API_SHM_SIZE=2gb
API_PIDS_LIMIT=256

# CPU training safety policy.
CPU_TRAINING_THREADS=4
CPU_DETECT_MAX_BATCH=4
CPU_SEGMENT_MAX_BATCH=1
CPU_TRAINING_MAX_IMAGE_SIZE=640

# GPU training safety policy. Empty GPU_ALLOWED_DEVICES permits any visible GPU.
GPU_DETECT_MAX_BATCH=8
GPU_SEGMENT_MAX_BATCH=2
GPU_TRAINING_MAX_IMAGE_SIZE=1280
GPU_ALLOWED_DEVICES=

# Maximum bytes accepted by every streamed upload endpoint.
YOLO_FACTORY_MAX_UPLOAD_BYTES=2147483648
TRAINING_MIN_FREE_DISK_GB=8
TRAINING_MIN_FREE_DISK_PERCENT=10
# Applied only when the runner can read Windows memory metrics.
TRAINING_MIN_AVAILABLE_COMMIT_GB=8
TRAINING_RUNTIME_MIN_AVAILABLE_COMMIT_GB=4
TRAINING_MIN_AVAILABLE_MEMORY_GB=4
